index 732c5935f9474646bed546d9d9431f654b295005..90886f6bc4e8320e7eac461316c34a092b04a482 100644
--- a/dist/index.cjs
+++ b/dist/index.cjs
@@ -3042,6 +3042,42 @@ class DocView {
             anchor = head = new DOMPos(dummy, 0);
             force = true;
         }
+        // PATCHED (InkStream): Windows TSF (notably under WebView2) may fail
+        // to arm the IME while the caret rests on an element node (empty
+        // lines render as <div class="cm-line"><br></div>, which has no text
+        // positions, so updateSelection collapses onto the line element).
+        // Mirror the Gecko empty-text-node workaround above so the caret
+        // always ends up inside a text node on Windows Chromium.
+        if (browser.chrome && browser.windows && main.empty && !this.hasComposition &&
+            anchor.node.nodeType == 1) {
+            let curSel = this.view.observer.selectionRange;
+            let domSelOnElement = !!(curSel.focusNode && curSel.focusNode.nodeType == 1);
+            let text = textNodeBefore(anchor.node, anchor.offset) || textNodeAfter(anchor.node, anchor.offset);
+            if (text) {
+                anchor = head = new DOMPos(text.node, text.offset);
+                // The current DOM anchor may be an "equivalent" element
+                // position; force the rewrite so the caret really moves into
+                // the text node.
+                if (domSelOnElement)
+                    force = true;
+            }
+            else {
+                // Reuse an adjacent empty text node (a dummy from a previous
+                // pass that the tile structure doesn't know about) instead of
+                // accumulating new ones until the next line sync.
+                let prev = anchor.offset ? anchor.node.childNodes[anchor.offset - 1] : null;
+                let next = anchor.node.childNodes[anchor.offset];
+                let dummy = prev && prev.nodeType == 3 && prev.nodeValue == "" ? prev
+                    : next && next.nodeType == 3 && next.nodeValue == "" ? next
+                        : document.createTextNode("");
+                let inserted = dummy != prev && dummy != next;
+                if (inserted)
+                    this.view.observer.ignore(() => anchor.node.insertBefore(dummy, next || null));
+                if (inserted || domSelOnElement)
+                    force = true;
+                anchor = head = new DOMPos(dummy, 0);
+            }
+        }
         let domSel = this.view.observer.selectionRange;
         // If the selection is already here, or in an equivalent position, don't touch it
         if (force || !domSel.focusNode || (!isEquivalentPosition(anchor.node, anchor.offset, domSel.anchorNode, domSel.anchorOffset) ||
